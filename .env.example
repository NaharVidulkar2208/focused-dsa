# ===================================================================
# DSA Focus - Environment Configuration
# ===================================================================
# Copy this file to .env and fill in the real values.
# DO NOT commit .env files to version control.
# .env files are already ignored via .gitignore.
# ===================================================================

# ── Lovable Cloud / Supabase ───────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ── YouTube Data API v3 ────────────────────────────────────────────
# Required for fetching video descriptions and auto-extracting
# lecture notes, assignments, and code links from video metadata.
#
# How to obtain:
#   1. Go to https://console.cloud.google.com/
#   2. Create/select a project
#   3. Enable "YouTube Data API v3" in the API Library
#   4. Go to Credentials → Create credentials → API key
#   5. Paste the key below
#
# If left empty or commented out, the app falls back to:
#   - LocalStorage cache for previously fetched videos
#   - Static/imported course content (no crash, no broken features)
#   - A console warning in development mode only
#
YOUTUBE_API_KEY=AIzaSyCawRxkr5pZhUUXTIMUJJNDsxXC76J71YE
